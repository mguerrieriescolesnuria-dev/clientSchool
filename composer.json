{
  "name": "clientschool/api",
  "description": "REST API for School Management - Teachers, Students, Subjects",
  "type": "project",
  "require": {
    "php": "^8.1",
    "vlucas/phpdotenv": "^5.6",
    "doctrine/orm": "^3.6",
    "symfony/cache": "^7.3",
    "symfony/var-exporter": "^7.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Database\\": "database/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "serve": "php -S localhost:8000 -t public"
  }
}
